<Window x:Class="Du_an_demo.View.DashBoard"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Du_an_demo.View"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="DashBoard" Height="760" Width="1280">
    <Border CornerRadius="25" Background="#121F2C">
        <Grid>
            <!-- Định nghĩa các cột -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <!-- Cột cho menu bên trái -->
                <ColumnDefinition Width="287*" />
                <ColumnDefinition Width="8*"/>
                <!-- Cột cho nội dung chính -->
            </Grid.ColumnDefinitions>

            <!-- Định nghĩa các hàng -->
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <!-- Thanh tiêu đề -->
                <RowDefinition Height="*" />
                <!-- Phần nội dung chính -->
                <RowDefinition Height="auto" />
                <!-- Phần chân trang (footer) -->
            </Grid.RowDefinitions>

            <!-- Left Menu -->
            <Border Grid.RowSpan="2" Background="#1C2E46" CornerRadius="25 0 0 25">
                <Grid>
                    <StackPanel VerticalAlignment="Top">
                        <!-- Menu Header -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 30 0 40">
                            <Ellipse Width="8" Height="8" Fill="#eb1700"/>
                            <Ellipse Width="8" Height="8" Fill="#ffaf01" Margin="7 0"/>
                            <Ellipse Width="8" Height="8" Fill="#009d00"/>
                        </StackPanel>

                        <!-- Các nút menu -->
                        <Button Height="50" Margin="10" Background="#2A3B52" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Button.ToolTip>
                                <ToolTip Content="Home" />
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="Home" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button Height="50" Margin="10" Background="#2A3B52" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Button.ToolTip>
                                <ToolTip Content="Employee Management" />
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="AccountGroup" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button Height="50" Margin="10" Background="#2A3B52" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Button.ToolTip>
                                <ToolTip Content="Menu Management" />
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="ClipboardText" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button Height="50" Margin="10" Background="#2A3B52" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Button.ToolTip>
                                <ToolTip Content="Reports" />
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="ChartBar" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button Height="50" Margin="10 320" Background="#2A3B52" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Click="LogoutButton_Click">
                            <Button.ToolTip>
                                <ToolTip Content="Logout" />
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="Logout" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Nội dung chính -->
            <Grid Grid.Column="1" Grid.Row="1" Margin="20,20,20,20" Grid.ColumnSpan="2">
                <Grid Background="Transparent" Margin="-52,-20,-40,678">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                        <materialDesign:ColorZone
                            Background="#7B81E0"
                            Mode="PrimaryMid"
            
                            Padding="16" Width="1180">
                            <DockPanel>
                                <StackPanel
                    
                                    Orientation="Horizontal"
                    
                                    materialDesign:RippleAssist.IsCentered="True">
                                    <ToggleButton
                        
                                        Style="{DynamicResource MaterialDesignHamburgerToggleButton}" Height="31" />
                                    <materialDesign:ColorZone
                        
                                        Mode="Standard"
                       
                                        Padding="8 4 8 4"
                        
                                        CornerRadius="2"
                        
                                        Panel.ZIndex="1"
                        
                                        Margin="16 0 0 0"
                        >
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="19*"/>
                                                <RowDefinition Height="3*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition
                                  
                                                    Width="Auto" />
                                                <ColumnDefinition
                                   
                                                    Width="*" />
                                                <ColumnDefinition
                                   
                                                    Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button
                              
                                                Style="{DynamicResource MaterialDesignToolButton}" Margin="0,0,0,-10" Grid.RowSpan="2">
                                                <materialDesign:PackIcon
                                   
                                                    Kind="Magnify"
                                    
                                                    Opacity=".56" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.55,-0.075" Width="16" />
                                            </Button>
                                            <TextBox
                              
                                                Grid.Column="1"
                                
                                                Margin="8 0 0 0"
                                
                                                materialDesign:HintAssist.Hint="Tìm kiếm..."
                               
                                                materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                
                                                BorderThickness="0"
                                
                                                MinWidth="200"
                                
                                                VerticalAlignment="Top" Grid.RowSpan="2" HorizontalAlignment="Left" Width="200" />
                                            <Button
                                    
                                                Style="{DynamicResource MaterialDesignToolButton}"
                               
 Grid.Column="2" Margin="0,0,0,-10" Grid.RowSpan="2"/>
                                        </Grid>
                                    </materialDesign:ColorZone>
                                </StackPanel>
                            </DockPanel>
                        </materialDesign:ColorZone>
                        <!-- Thanh tìm kiếm với Material Design -->
                    </StackPanel>
                </Grid>


                <!-- Các phần thông tin tổng quan -->


                <!-- Nội dung chi tiết -->
                <StackPanel Margin="-20,47,0,0">
                    <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
